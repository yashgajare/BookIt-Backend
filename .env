# === MySQL ===
MYSQL_ROOT_PASSWORD=your_mysql_root_password
MYSQL_DATABASE=bookit
MYSQL_USER=bookituser
MYSQL_PASSWORD=bookitpass

# === Spring Boot ===
SPRING_DATASOURCE_URL=jdbc:mysql://mysql:3306/bookit
SPRING_DATASOURCE_USERNAME=bookituser
SPRING_DATASOURCE_PASSWORD=bookitpass
SPRING_DATASOURCE_DRIVER_CLASS_NAME=com.mysql.cj.jdbc.Driver
SPRING_JPA_HIBERNATE_DDL_AUTO=update

SPRING_SECURITY_USER_NAME=admin
SPRING_SECURITY_USER_PASSWORD=admin123
LOGGING_LEVEL_ORG_SPRINGFRAMEWORK_SECURITY=INFO
LOGGING_LEVEL_ROOT=INFO

SPRING_APP_JWTSECRET=mysecretjwtkey
SPRING_APP_JWTEXPIRATIONMS=86400000
SPRING_DEVTOOLS_RESTART_ENABLED=false

FRONTEND_URL=https://bookit.fivestacks.in

SPRING_MAIL_HOST=smtp.gmail.com
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=youremail@gmail.com
SPRING_MAIL_PASSWORD=your-email-password
SPRING_MAIL_PROPERTIES_MAIL_SMTP_AUTH=true
SPRING_MAIL_PROPERTIES_MAIL_SMTP_STARTTLS_ENABLE=true

SPRING_SERVLET_MULTIPART_MAX_FILE_SIZE=10MB
SPRING_SERVLET_MULTIPART_MAX_REQUEST_SIZE=10MB
